# --- 로컬 개발용 (.env) ---------------------------------------------------
# App DB 접속 (비-슈퍼유저 roi_app 역할)
DATABASE_URL="postgresql://roi_app:roi_app_pw@localhost:5432/roi?schema=public"
# 로컬은 풀러가 없으므로 DATABASE_URL과 동일하게 둔다(스키마의 directUrl 요구사항 충족).
DIRECT_URL="postgresql://roi_app:roi_app_pw@localhost:5432/roi?schema=public"

# Auth.js
AUTH_SECRET="generate-with: npx auth secret"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# 허용 도메인 (이 도메인 이메일만 로그인 허용)
ALLOWED_EMAIL_DOMAIN="huno.kr"

# 프로덕션(Supabase) 값은 .env.production.example 참고.
