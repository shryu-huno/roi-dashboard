generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // 런타임(앱): 커넥션 풀러 경유(Supabase는 6543 포트, ?pgbouncer=true). 로컬은 다이렉트와 동일.
  url       = env("DATABASE_URL")
  // 마이그레이션/introspection: 풀러를 우회한 다이렉트 연결(Supabase는 5432). 로컬은 DATABASE_URL과 동일.
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SETTLEMENT
  PM
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum TaskSource {
  MANUAL
  PDF
}

enum ExpenseCategory {
  CORPORATE_CARD
  PERSONAL_CARD
  LABOR_COUNSELOR
  LABOR_INSTRUCTOR
  EDUCATION_PROGRAM
  PROMOTION_OFFLINE
  PROMOTION_EVENT
  OPS_TRANSPORT
  OPS_LODGING
  OPS_FOOD
  OPS_MEETING
  TEST_MATERIAL
  GENERAL_ETC
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  image     String?
  emailVerified DateTime? // Auth.js Prisma 어댑터 필수 필드
  role      Role?
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  managedClients ClientManager[]
  accounts  Account[]
  sessions  Session[]

  @@index([role])
  @@index([status])
}

model Client {
  id           String   @id @default(cuid())
  name         String
  status       String   @default("진행중")
  industry     String?
  contractStart DateTime?
  contractEnd   DateTime?
  businessType String?  // 사업자 구분: 휴노 | 휴노INC
  hyundaiEasywel Boolean @default(false) // 현대이지웰 소개로 계약한 고객사
  contactName  String?  // 담당자명 (프로그램 대시보드의 협조요청·확정 메일 수신처)
  contactEmail String?  // 담당자 이메일
  contactPhone String?  // 담당자 전화
  billingCycle String[] @default([]) // 청구 주기(복수): 월/분기/중간/최종
  reportCycle  String[] @default([]) // 보고 주기(복수): 월/분기/중간/최종
  deletedAt    DateTime? // 소프트 삭제(보관). null=활성, 값=보관됨(목록에서 숨김).
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managers     ClientManager[]
  tasks        Task[]
  billings     MonthlyBilling[]
  deposits     MonthlyDeposit[]
  expenses     Expense[]
}

// 고객사–담당PM 다대다 조인. 한 고객사에 여러 PM을 지정할 수 있다.
model ClientManager {
  clientId String
  userId   String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([clientId, userId])
  @@index([userId])
}

model Task {
  id             String     @id @default(cuid())
  clientId       String
  client         Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name           String
  unitPrice      Int
  contractCount  Int?
  contractAmount Int?
  source         TaskSource @default(MANUAL)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  performances   MonthlyPerformance[]

  @@index([clientId])
}

model MonthlyPerformance {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  year      Int
  month     Int
  count     Int
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, year, month])
  @@index([year, month])
}

model MonthlyBilling {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  year      Int
  month     Int
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, year, month])
  @@index([year, month])
}

model MonthlyDeposit {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  year      Int
  month     Int
  amount    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, year, month])
  @@index([year, month])
}

model Expense {
  id        String          @id @default(cuid())
  clientId  String
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  year      Int
  month     Int
  category  ExpenseCategory
  amount    Int
  memo      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([clientId, year, month, category])
  @@index([clientId, year, month])
}

// --- Auth.js (NextAuth) 어댑터 모델 ---
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
